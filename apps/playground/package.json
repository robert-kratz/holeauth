    "@holeauth/nextjs": "workspace:*",
    "@holeauth/passkey-drizzle": "workspace:*",
    "@holeauth/plugin-2fa": "workspace:*",
    "@holeauth/plugin-idp": "workspace:*",
    "@holeauth/plugin-passkey": "workspace:*",
    "@holeauth/plugin-rbac": "workspace:*",
    "@holeauth/rbac-drizzle": "workspace:*",
    "@holeauth/rbac-yaml": "workspace:*",
    "@holeauth/react": "workspace:*",
    "@node-rs/argon2": "^2.0.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "jose": "^5.9.3",
    "next": "^16.2.4",
    "pg": "^8.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "superjson": "^2.2.1",
    "zod": "^3.23.0"
