# OIDC Issuer (main playground)
HOLEAUTH_ISSUER=http://localhost:3000/api/auth

# Client credentials — created via main playground /developer/apps or the
# `pnpm register-app` helper. For public clients leave CLIENT_SECRET empty.
CLIENT_ID=
CLIENT_SECRET=
CLIENT_TYPE=confidential

# Where the main IdP redirects after /oauth2/authorize
REDIRECT_URI=http://localhost:3001/oidc/callback

# Requested scopes (space-separated)
SCOPES=openid profile email

# Local database (separate from the main playground)
DATABASE_URL=postgres://holeauth:holeauth@localhost:54329/client_playground

# Local session cookie signing secret
SESSION_SECRET=dev-client-secret-change-me
